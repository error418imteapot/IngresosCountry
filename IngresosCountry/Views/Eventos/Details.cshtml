@model Evento
@{
    ViewData["Title"] = "Detalle Evento";
    var participantes = ViewBag.Participantes as List<EventoParticipante> ?? new List<EventoParticipante>();
}

<div class="mb-4">
    <h3 class="fw-bold"><i class="bi bi-calendar-event me-2"></i>@Model.Nombre</h3>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">Información del Evento</div>
            <div class="card-body">
                <p><strong>Descripción:</strong> @(Model.Descripcion ?? "N/A")</p>
                <p><strong>Inicio:</strong> @Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Fin:</strong> @Model.FechaFin.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Ubicación:</strong> @(Model.Ubicacion ?? "N/A")</p>
                <p><strong>Capacidad:</strong> @(Model.Capacidad?.ToString() ?? "Sin límite")</p>
                <p><strong>Organizador:</strong> @(Model.OrganizadorNombre ?? "N/A")</p>
                <p><strong>Estado:</strong> <span class="badge bg-primary">@Model.Estado</span></p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between">
                <span>Participantes (@participantes.Count)</span>
            </div>
            <div class="card-body">
                <!-- Add Participant Form -->
                <form asp-action="AddParticipante" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="EventoId" value="@Model.Id" />
                    <div class="row g-2">
                        <div class="col-5">
                            <input name="Nombre" class="form-control form-control-sm" placeholder="Nombre completo" required />
                        </div>
                        <div class="col-3">
                            <input name="DocumentoIdentidad" class="form-control form-control-sm" placeholder="Documento" />
                        </div>
                        <div class="col-2">
                            <select name="TipoParticipante" class="form-select form-select-sm">
                                <option value="Externo">Externo</option>
                                <option value="Socio">Socio</option>
                                <option value="Invitado">Invitado</option>
                            </select>
                        </div>
                        <div class="col-2">
                            <button type="submit" class="btn btn-sm btn-success w-100">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Tipo</th>
                                <th>Documento</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in participantes)
                            {
                                <tr>
                                    <td>@p.Nombre</td>
                                    <td><span class="badge bg-secondary">@p.TipoParticipante</span></td>
                                    <td>@(p.DocumentoIdentidad ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
        <i class="bi bi-pencil me-1"></i>Editar
    </a>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>