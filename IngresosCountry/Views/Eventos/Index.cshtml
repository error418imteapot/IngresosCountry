@model List<Evento>
@{
    ViewData["Title"] = "Eventos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-calendar-event-fill me-2"></i>Eventos</h3>
        <p class="text-muted mb-0">Gestión de eventos del club</p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Nuevo Evento
    </a>
</div>

<!-- Filters -->
<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.Estado == null ? "btn-dark" : "btn-outline-dark")">Todos</a>
    <a asp-action="Index" asp-route-estado="Programado" class="btn btn-sm @(ViewBag.Estado == "Programado" ? "btn-primary" : "btn-outline-primary")">Programados</a>
    <a asp-action="Index" asp-route-estado="EnCurso" class="btn btn-sm @(ViewBag.Estado == "EnCurso" ? "btn-success" : "btn-outline-success")">En Curso</a>
    <a asp-action="Index" asp-route-estado="Finalizado" class="btn btn-sm @(ViewBag.Estado == "Finalizado" ? "btn-secondary" : "btn-outline-secondary")">Finalizados</a>
</div>

<div class="row g-4">
    @if (Model.Any())
    {
        @foreach (var evento in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-dark text-white">
                        <h6 class="mb-0">@evento.Nombre</h6>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">@(evento.Descripcion ?? "Sin descripción")</p>
                        <div class="mb-2">
                            <i class="bi bi-calendar me-1"></i>
                            @evento.FechaInicio.ToString("dd/MM/yyyy HH:mm") - @evento.FechaFin.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="mb-2">
                            <i class="bi bi-geo-alt me-1"></i>@(evento.Ubicacion ?? "Sin ubicación")
                        </div>
                        <div class="mb-2">
                            <i class="bi bi-people me-1"></i>@evento.TotalParticipantes participantes
                            @if (evento.Capacidad.HasValue)
                            {
                                <span class="text-muted">/ @evento.Capacidad</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(evento.OrganizadorNombre))
                        {
                            <div class="mb-2">
                                <i class="bi bi-person me-1"></i>Organizador: @evento.OrganizadorNombre
                            </div>
                        }
                        @{
                            var estadoClass = evento.Estado switch
                            {
                                "Programado" => "primary",
                                "EnCurso" => "success",
                                "Finalizado" => "secondary",
                                "Cancelado" => "danger",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@estadoClass">@evento.Estado</span>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@evento.Id" class="btn btn-sm btn-outline-info">
                            <i class="bi bi-eye me-1"></i>Ver
                        </a>
                        <a asp-action="Edit" asp-route-id="@evento.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
            No hay eventos registrados.
        </div>
    }
</div>