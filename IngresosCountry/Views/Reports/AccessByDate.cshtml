@model List<AccessReportItem>
@{
    ViewData["Title"] = "Reporte de Accesos por Fecha";
}

<div class="mb-4">
    <h3 class="fw-bold"><i class="bi bi-calendar-range me-2"></i>Accesos por Fecha</h3>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Desde</label>
                <input type="date" name="fechaDesde" class="form-control" value="@(((DateTime)ViewBag.FechaDesde).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Hasta</label>
                <input type="date" name="fechaHasta" class="form-control" value="@(((DateTime)ViewBag.FechaHasta).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary"><i class="bi bi-funnel me-1"></i>Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo Visitante</th>
                        <th>Resultado</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-info">@item.TipoVisitante</span></td>
                            <td>
                                <span class="badge bg-@(item.ResultadoAcceso == "Aprobado" ? "success" : "danger")">
                                    @item.ResultadoAcceso
                                </span>
                            </td>
                            <td><strong>@item.Total</strong></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-secondary">
                        <td colspan="3"><strong>Total General</strong></td>
                        <td><strong>@Model.Sum(x => x.Total)</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver a Reportes</a>
</div>